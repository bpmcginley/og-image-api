# Copy this file to .env and fill in your own values.

# Port the server listens on
PORT=3000

# Public base URL of your deployment (used in docs + Stripe redirects)
# e.g. https://ogapi.yourdomain.com
BASE_URL=http://localhost:3000

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys (YOUR account)
STRIPE_SECRET_KEY=sk_test_xxx
# Create a recurring Price in the Stripe dashboard and paste its ID here
STRIPE_PRICE_ID=price_xxx
# From the webhook endpoint you create in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Plans / quotas (monthly request counts) ---
FREE_MONTHLY_QUOTA=200
PRO_MONTHLY_QUOTA=50000
